# skip unless which("jq")
fn jq_match_query(filename, query, pattern) {
    > jq -rM '${query}' ${filename}
    <? ${pattern}
    match_ok()
}

# skip unless which("jq")
fn jq_extract(filename, query) {
    > jq -rM '${query}' ${filename}
    <? ^jq (.*)$
    <? ^(.+)$
    let value = $0
    match_ok()
    value
}
