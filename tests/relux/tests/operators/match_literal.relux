test "basic literal match" {
    """
    Verify literal match finds exact substring in output buffer.

    The first match hits the echoed command, the second hits the output.
    This demonstrates that literal match is a substring search from cursor.
    """
    shell s {
        > echo hello-relux
        <= echo hello-relux
        <= hello-relux
    }
}

test "literal match is substring" {
    """
    Verify literal match succeeds on a substring of the output.
    """
    shell s {
        > echo "the quick brown fox"
        <= quick brown
    }
}

test "literal match with special regex chars" {
    """
    Verify literal match treats regex metacharacters as plain text.
    """
    shell s {
        > echo "price is $10.00 (USD)"
        <= $10.00 (USD)
    }
}

test "literal match with variable interpolation" {
    """
    Verify variables are interpolated in literal match payloads.
    """
    shell s {
        let expected = "hello"
        > echo hello
        <= ${expected}
    }
}

test "literal match advances cursor" {
    """
    Verify each literal match advances the cursor so subsequent
    matches search from the new position.
    """
    shell s {
        > echo first
        > echo second
        > echo third
        <= first
        <= second
        <= third
    }
}
