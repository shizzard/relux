test "check detects impure operator in pure function" {
    """
    Verify relux check reports when a pure function uses a shell operator.
    """
    shell s {
        > ${__RELUX} check --manifest ${__RELUX_TEST_ROOT}/fixtures/Relux.toml 2>&1
        <? shell operation in pure context
        match_prompt()
        match_exit_code(1)
    }
}
