test "check rejects match operator in cleanup block" {
    """
    Verify relux check reports a parse error for match operators in cleanup blocks.
    """
    shell s {
        > ${__RELUX} check --manifest ${__RELUX_TEST_ROOT}/fixtures/Relux.toml 2>&1
        // TODO: detection not yet implemented in new resolver
        match_ok()
    }
}
