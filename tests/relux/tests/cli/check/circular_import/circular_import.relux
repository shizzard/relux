test "check detects circular import" {
    """
    Verify relux check reports circular module imports.
    """
    shell s {
        > relux check --manifest ${__RELUX_TEST_ROOT}/fixtures/Relux.toml 2>&1
        <? circular import
        <? cycle: b -> a -> b
        match_prompt()
        match_exit_code(1)
    }
}
