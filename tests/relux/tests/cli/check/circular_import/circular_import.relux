test "check detects circular import" {
    """
    Verify relux check reports circular module imports.
    """
    shell s {
        > ${__RELUX} check --manifest ${__RELUX_TEST_ROOT}/fixtures/Relux.toml 2>&1
        // TODO: detection not yet implemented in new resolver
        match_prompt()
        match_exit_code(0)
    }
}
