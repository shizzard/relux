test "check detects import not exported" {
    """
    Verify relux check reports a selective import of a name not exported by the module.
    """
    shell s {
        > relux check --manifest ${__RELUX_TEST_ROOT}/fixtures/Relux.toml 2>&1
        <? not exported
        match_prompt()
        match_exit_code(1)
    }
}
