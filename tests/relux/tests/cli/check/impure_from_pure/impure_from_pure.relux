test "check detects impure function called from pure context" {
    """
    Verify relux check reports when a pure function calls an impure function.
    """
    shell s {
        > ${__RELUX} check --manifest ${__RELUX_TEST_ROOT}/fixtures/Relux.toml 2>&1
        <? shell operation in pure context
        match_not_ok(1)
    }
}
