test "skip if eq: skips when var matches" {
    """
    Verify skip-if equality marker skips when the variable equals the value.
    """
    shell s {
        > MY_VAR=yes ${__RELUX} run --progress plain --manifest ${__RELUX_TEST_ROOT}/fixtures/Relux.toml 2>&1
        <? 1 skipped
        match_ok()
    }
}

test "skip if eq: runs when var differs" {
    """
    Verify skip-if equality marker runs when the variable does not match.
    """
    shell s {
        > MY_VAR=no ${__RELUX} run --progress plain --manifest ${__RELUX_TEST_ROOT}/fixtures/Relux.toml 2>&1
        <? 1 passed
        match_ok()
    }
}

test "skip if eq: runs when var is unset" {
    """
    Verify skip-if equality marker runs when the variable is unset.
    """
    shell s {
        > ${__RELUX} run --progress plain --manifest ${__RELUX_TEST_ROOT}/fixtures/Relux.toml 2>&1
        <? 1 passed
        match_ok()
    }
}
