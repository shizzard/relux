test "flaky marker with no retries cancels on first attempt" {
    """
    With max_retries=0 (default), flaky marker is documentary only.
    The fixture test exceeds its own ~50ms test timeout (90ms sleep),
    so with no retries it reports a Cancelled outcome.
    """
    shell s {
        > ${__RELUX} run --progress plain --manifest ${__RELUX_TEST_ROOT}/fixtures/Relux.toml 2>&1
        <? 1 cancelled
        match_not_ok(1)
    }
}

# flaky if CI
test "flaky retries recovers on third attempt" {
    """
    With --flaky-retries 3, the fixture test fails twice (timeout too short)
    then passes on the third attempt (timeout scaled by 1.5^2 = 2.25x).
    """
    shell s {
        > ${__RELUX} run --progress plain --manifest ${__RELUX_TEST_ROOT}/fixtures/Relux.toml --flaky-retries 3 2>&1
        <? 1 passed.*2 flaky retries
        match_ok()
    }
}
