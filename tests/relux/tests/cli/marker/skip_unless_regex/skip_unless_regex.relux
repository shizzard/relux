test "skip unless regex: runs when var matches pattern" {
    """
    Verify skip-unless regex marker runs when the variable matches the pattern.
    """
    shell s {
        > MY_VAR=yes relux run --manifest ${__RELUX_TEST_ROOT}/fixtures/Relux.toml 2>&1
        <? 1 passed
        match_ok()
    }
}

test "skip unless regex: skips when var does not match" {
    """
    Verify skip-unless regex marker skips when the variable does not match.
    """
    shell s {
        > MY_VAR=no relux run --manifest ${__RELUX_TEST_ROOT}/fixtures/Relux.toml 2>&1
        <? 1 skipped
        match_ok()
    }
}

test "skip unless regex: skips when var is unset" {
    """
    Verify skip-unless regex marker skips when the variable is unset.
    """
    shell s {
        > relux run --manifest ${__RELUX_TEST_ROOT}/fixtures/Relux.toml 2>&1
        <? 1 skipped
        match_ok()
    }
}
