# skip if SKIP_EFFECT
effect Guarded {
    shell s {
        > echo "effect ran"
        <? ^effect ran$
    }
}

test "depends on conditionally skipped effect" {
    """
    Depend on an effect with a conditional skip marker.
    """
    start Guarded as s
    shell s {
        > echo "test body ran"
        <? ^test body ran$
    }
}
