test "skip unless: runs when var is set" {
    """
    Verify skip-unless marker runs the test when the condition variable is set.
    """
    shell s {
        > MY_VAR=1 relux run --manifest ${__RELUX_TEST_ROOT}/fixtures/Relux.toml 2>&1
        <? 1 passed
        match_ok()
    }
}

test "skip unless: skips when var is unset" {
    """
    Verify skip-unless marker skips the test when the condition variable is unset.
    """
    shell s {
        > relux run --manifest ${__RELUX_TEST_ROOT}/fixtures/Relux.toml 2>&1
        <? 1 skipped
        match_ok()
    }
}
