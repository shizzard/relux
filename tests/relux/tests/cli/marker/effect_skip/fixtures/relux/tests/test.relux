# skip
effect Skipped {
    expose shell s
    shell s {
        > echo "effect ran"
        <? ^effect ran$
    }
}

test "depends on skipped effect" {
    """
    Depend on a skipped effect.
    """
    start Skipped as S
    shell S.s {
        > echo "should not run"
        <? ^should not run$
    }
}
