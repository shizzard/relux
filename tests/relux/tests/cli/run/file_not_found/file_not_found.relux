test "run exits 1 for non-existent file" {
    """
    Verify relux run reports a clear error when given a non-existent file path.
    # TODO: non-existent file silently runs 0 tests instead of erroring
    """
    shell s {
        > ${__RELUX} run --progress plain -f relux/tests/nonexistent.relux --manifest ${__RELUX_TEST_ROOT}/fixtures/Relux.toml 2>&1
        <? 0 passed
        match_exit_code(0)
    }
}
