test "run exits 1 for non-existent file" {
    """
    Verify relux run reports a clear error when given a non-existent file path.
    """
    shell s {
        > relux run relux/tests/nonexistent.relux --manifest ${__RELUX_TEST_ROOT}/fixtures/Relux.toml 2>&1
        <? ^error: test file not found: relux/tests/nonexistent\.relux$
        match_exit_code(1)
    }
}
