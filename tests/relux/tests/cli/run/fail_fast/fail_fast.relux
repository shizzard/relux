test "fail-fast stops after first failure" {
    """
    Verify relux run --strategy fail-fast stops after the first test failure.
    """
    shell s {
        > relux run --strategy fail-fast --manifest ${__RELUX_TEST_ROOT}/fixtures/Relux.toml 2>&1
        <? 1 failed
        match_prompt()
        match_exit_code(1)
    }
}
