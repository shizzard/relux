effect E0 {
    expose shell s
    shell s {
        > echo "E0 setup"
        <? ^E0 setup$
    }
    cleanup {
        > echo "E0" >> ${MARKER_FILE}
        match_ok()
    }
}

effect E1 {
    start E0 as Zero
    expose shell Zero.s as s
    shell Zero.s {
        !? UH_OH
        > echo UH_OH
        match_ok()
    }
    cleanup {
        > echo "E1" >> ${MARKER_FILE}
        match_ok()
    }
}

effect E2 {
    start E1 as One
    expose shell One.s as s
    shell One.s {
        > echo "E2 setup"
        <? ^E2 setup$
    }
    cleanup {
        > echo "E2" >> ${MARKER_FILE}
        match_ok()
    }
}

test "nested-fail-path" {
    start E2 as Two
    shell Two.s {
        > echo body
        <? ^body$
    }
}
