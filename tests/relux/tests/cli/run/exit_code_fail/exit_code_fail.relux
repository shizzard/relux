test "run exits 1 when a test fails" ~300ms {
    """
    Verify relux run exits with code 1 when any test fails.
    """
    shell s {
        > ${__RELUX} run --progress plain --manifest ${__RELUX_TEST_ROOT}/fixtures/Relux.toml 2>&1
        <? 1 failed
        match_prompt()
        match_exit_code(1)
    }
}
