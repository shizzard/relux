test "run reports match timeout" ~300ms {
    """
    Verify relux run reports a match timeout when a pattern is never found.
    """
    shell s {
        > relux run --manifest ${__RELUX_TEST_ROOT}/fixtures/Relux.toml 2>&1
        <? timed out waiting for
        match_prompt()
        match_exit_code(1)
    }
}
