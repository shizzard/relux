test "run reports assignment to undeclared variable" {
    """
    Verify relux run reports when code assigns to a variable not declared with let.
    """
    shell s {
        > ${__RELUX} run --progress plain --manifest ${__RELUX_TEST_ROOT}/fixtures/Relux.toml 2>&1
        <? assignment to undeclared variable
        match_not_ok(1)
    }
}
