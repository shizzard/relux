test "failure mid-setup still releases acquired dependencies" ~60s {
    """
    Verifies the RAII failure-path: when E1's setup fails *after*
    successfully acquiring E0, bootstrap_effect runs E1's own
    cleanup body (best-effort) and then releases the E0 guard, so
    both cleanups run in the expected reverse order (effect's own
    before its deps').
    """
    let marker = "${__RELUX_TEST_ARTIFACTS}/order"

    shell s {
        > export MARKER_FILE=${marker}
        match_ok()
        > rm -f ${marker}
        match_ok()

        > ${__RELUX} run --progress plain --manifest ${__RELUX_TEST_ROOT}/fixtures/Relux.toml 2>&1
        <? 1 failed
        match_not_ok(1)

        // Both cleanups ran, even though E1's setup failed before the
        // test body ever started. E1's own cleanup runs first (effect
        // before its deps), then E0's.
        > cat ${marker}
        <? ^E1$
        <? ^E0$
        match_ok()
    }
}
