test "run reports negative match failure" ~300ms {
    """
    Verify relux run reports when a negative match finds the unwanted pattern.
    """
    shell s {
        > relux run --manifest ${__RELUX_TEST_ROOT}/fixtures/Relux.toml 2>&1
        <? negative match failed
        match_prompt()
        match_exit_code(1)
    }
}
