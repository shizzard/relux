fn set_timeout_inside() {
    ~200ms
    > echo "in fn"
    <? ^in fn$
}

fn set_fail_pattern_inside() {
    !? BOOM
    > echo "in fn"
    <? ^in fn$
}

test "timeout set inside function does not persist in caller" {
    """
    Verify a scoped timeout set inside a function is restored to
    the caller's timeout after the function returns.
    """
    shell s {
        ~3s
        set_timeout_inside()
        > sh -c 'sleep 0.5 && echo delayed'
        <? ^delayed$
    }
}

test "fail pattern set inside function does not persist in caller" {
    """
    Verify a fail pattern set inside a function is restored to the
    caller's fail pattern after the function returns.
    """
    shell s {
        set_fail_pattern_inside()
        > echo "BOOM is safe now"
        <? ^BOOM is safe now$
    }
}
