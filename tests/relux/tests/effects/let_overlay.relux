effect Echo -> s {
    shell s {
        > echo "PORT=${PORT}"
        <? ^PORT=\d+$
        match_ok()
    }
}

test "test-level let visible in effect overlay" {
    """
    Verify that a test-level let binding is available to effect overlay expressions.
    The effect receives the port via overlay and echoes it back.
    """
    let port = available_port()
    need Echo as s { PORT = port }
    shell s {
        > echo "ok"
        <? ^ok$
    }
}

test "multiple lets feed multiple overlays" {
    """
    Verify that multiple test-level lets can feed overlays for different effects.
    """
    let port_a = available_port()
    let port_b = available_port()
    need Echo as s { PORT = port_a }
    shell s {
        > echo "got port"
        <? ^got port$
    }
}
