effect Inner {
  expect INNER_VAL
  expose shell inner
  shell inner {
    > export INNER_STATE="${INNER_VAL}"
    match_ok()
  }
}

effect Outer {
  expect OUTER_VAL
  start Inner as Dep { INNER_VAL = OUTER_VAL }
  expose shell Dep.inner as wrapped
  shell local {
    > echo "outer setup"
    match_ok()
  }
}

test "composed effect exposes inner shell via qualified expose" {
  """
  Verify that an outer effect can re-expose an inner effect's shell
  using qualified expose syntax, and the test can access it via
  dot notation through the outer alias.
  """
  start Outer as O { OUTER_VAL = "from_test" }
  shell O.wrapped {
    > echo $$INNER_STATE
    <? ^from_test$
    match_ok()
  }
}
