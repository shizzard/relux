effect StartService {
    shell svc {
        > echo "service ready"
        <? ^service ready$
    }
}

effect PrepareEnv {
    shell env {
        > export SETUP_VAR=initialized
        match_ok()
        > echo "setup done"
        <? ^setup done$
    }
}

test "effect sets up shell before test runs" {
    """
    Verify an effect's shell block executes and completes before
    the test body begins.
    """
    start StartService as worker
    shell worker {
        > echo "test using effect shell"
        <? ^test using effect shell$
    }
}

test "effect shell retains state from setup" {
    """
    Verify state established during effect setup (environment
    variables, working directory, etc.) persists into the test.
    """
    start PrepareEnv as env
    shell env {
        > echo $$SETUP_VAR
        <? ^initialized$
    }
}

effect SideEffectOnly {
    shell svc {
        > touch ${__RELUX_TEST_ARTIFACTS}/side-effect-marker
        match_ok()
    }
}

test "bare start runs effect but does not expose shell" {
    """
    Verify that start without as runs the effect for side effects
    but the exported shell is not accessible — shell s creates
    a fresh local shell without the effect's state.
    """
    start SideEffectOnly
    shell s {
        > test -f ${__RELUX_TEST_ARTIFACTS}/side-effect-marker && echo "effect ran"
        <? ^effect ran$
    }
}
