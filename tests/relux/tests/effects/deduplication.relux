effect Counter -> ctr {
    shell ctr {
        > export COUNT=0
        match_ok()
        > COUNT=$$(($$COUNT + 1)) && echo $$COUNT
        <? ^1$
    }
}

effect Parameterized -> svc {
    shell svc {
        > export SVC_LABEL=${LABEL}
        match_ok()
    }
}

test "same effect needed twice shares one instance" {
    """
    Verify two needs for the same effect (same identity tuple) reuse
    a single instance — the counter is incremented once, not twice.
    """
    need Counter as c1
    need Counter as c2
    shell c1 {
        > echo $$COUNT
        <? ^1$
    }
    shell c2 {
        > echo $$COUNT
        <? ^1$
    }
}

pure fn tag() {
    let t = "v1"
}

effect SetupOnce -> s {
    shell s {
        > MARKER="${__RELUX_TEST_ARTIFACTS}/dedup-marker"
        match_ok()
        > if [ -f "$$MARKER" ]; then echo "DUPLICATE"; else touch "$$MARKER" && echo "FIRST"; fi
        <? ^FIRST$
        match_ok()
    }
}

test "call-expression overlays at different positions deduplicate" {
    """
    Verify two needs with identical call-expression overlay values
    deduplicate to a single instance, even though the call sites
    appear at different source positions. If two instances are created
    instead of one, the second setup will find the marker file and
    print DUPLICATE, failing the FIRST match.
    """
    need SetupOnce as s1 {
        TAG = tag()
    }
    need SetupOnce as s2 {
        TAG = tag()
    }
    shell s1 {
        > echo ok
        <? ^ok$
        match_ok()
    }
}

test "different overlays create separate instances" {
    """
    Verify two needs for the same effect with different overlay values
    create separate instances, each with their own shell and overlay.
    """
    need Parameterized as a {
        LABEL = "alpha"
    }
    need Parameterized as b {
        LABEL = "beta"
    }
    shell a {
        > echo $$SVC_LABEL
        <? ^alpha$
    }
    shell b {
        > echo $$SVC_LABEL
        <? ^beta$
    }
}
