effect Server {
  expose srv
  shell srv {
    > export SERVER_STATUS=running
    match_ok()
  }
}

test "dot-access shell mixed with local shell" {
  """
  Verify that dot-access effect shells and local shells can coexist
  in the same test body.
  """
  start Server as s
  shell s.srv {
    > echo $$SERVER_STATUS
    <? ^running$
    match_ok()
  }
  shell local {
    > echo "local shell"
    <? ^local shell$
    match_ok()
  }
}

test "multiple dot-access blocks on same effect" {
  """
  Verify that the same effect shell can be accessed via dot notation
  multiple times, with state persisting between blocks.
  """
  start Server as s
  shell s.srv {
    > export VISIT=first
    match_ok()
  }
  shell s.srv {
    > echo $$VISIT
    <? ^first$
    match_ok()
  }
}
