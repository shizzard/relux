test "sleep pauses execution" {
    """
    Verify sleep() pauses for at least the requested duration by
    measuring elapsed time with the date command.
    """
    shell s {
        > T1=$$(date +%s) && sleep 0 && echo "start=$$T1"
        <? ^start=([0-9]+)$
        let before = ${1}
        sleep("1s")
        > T2=$$(date +%s) && echo "elapsed=$$(( $$T2 - ${before} ))"
        <? ^elapsed=([0-9]+)$
        let diff = ${1}
        > test ${diff} -ge 1 && echo "ok"
        <? ^ok$
    }
}

test "sleep returns empty string" {
    """
    Verify sleep() returns an empty string as its result value.
    """
    shell s {
        let result = sleep("100ms")
        > echo "result='${result}'"
        <? ^result=''$
    }
}
